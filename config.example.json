{
  "truenas": {
    "host": "truenas.local",
    "username": "coolercontrol",
    "api_key": "replace-me",
    "tls": true,
    "tls_verify": false,
    "disk_names": []
  },
  "export": {
    "directory": "/var/lib/truenas-coolercontrol-sensors",
    "write_per_disk": true,
    "write_status_json": true
  },
  "polling": {
    "poll_interval_seconds": 300,
    "connect_timeout_seconds": 15,
    "stale_after_seconds": 900,
    "failsafe_temperature_c": 55
  }
}
